<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <!--
    Copies CEF native files to the output directory.
    The runtime identifier determines which platform files are copied.
    Native files come from the platform-specific sub-packages
    (Harry.Robust.Natives.Cef.win-x64, etc.) via runtimes/<rid>/native/.
  -->

  <!-- Windows x64 -->
  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'win-x64' Or ('$(RuntimeIdentifier)' == '' And '$([MSBuild]::IsOSPlatform(Windows))' == 'true')">
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.win-x64\146.0.8\runtimes\win-x64\native\**\*"
          CopyToOutputDirectory="PreserveNewest"
          Link="%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- Linux x64 -->
  <ItemGroup Condition="'$(RuntimeIdentifier)' == 'linux-x64' Or ('$(RuntimeIdentifier)' == '' And '$([MSBuild]::IsOSPlatform(Linux))' == 'true')">
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.linux-x64\146.0.8\runtimes\linux-x64\native\**\*"
          CopyToOutputDirectory="PreserveNewest"
          Link="%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- macOS: detect architecture -->
  <PropertyGroup Condition="'$([MSBuild]::IsOSPlatform(OSX))' == 'true' And '$(RuntimeIdentifier)' == ''">
    <_RnwMacRid Condition="'$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' == 'Arm64'">osx-arm64</_RnwMacRid>
    <_RnwMacRid Condition="'$([System.Runtime.InteropServices.RuntimeInformation]::OSArchitecture)' != 'Arm64'">osx-x64</_RnwMacRid>
  </PropertyGroup>
  <PropertyGroup Condition="'$(RuntimeIdentifier)' != '' And $(RuntimeIdentifier.StartsWith('osx'))">
    <_RnwMacRid>$(RuntimeIdentifier)</_RnwMacRid>
  </PropertyGroup>

  <ItemGroup Condition="'$(_RnwMacRid)' != ''">
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.$(_RnwMacRid)\146.0.8\runtimes\$(_RnwMacRid)\native\Chromium Embedded Framework.framework\**\*"
          CopyToOutputDirectory="PreserveNewest"
          Link="Frameworks\Chromium Embedded Framework.framework\%(RecursiveDir)%(Filename)%(Extension)" />
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.$(_RnwMacRid)\146.0.8\runtimes\$(_RnwMacRid)\native\Robust.Client.WebView"
          CopyToOutputDirectory="PreserveNewest"
          Link="Robust.Client.WebView" />
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.$(_RnwMacRid)\146.0.8\runtimes\$(_RnwMacRid)\native\librobust_native_webview.dylib"
          CopyToOutputDirectory="PreserveNewest"
          Link="librobust_native_webview.dylib" />
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.$(_RnwMacRid)\146.0.8\runtimes\$(_RnwMacRid)\native\libEGL.dylib"
          CopyToOutputDirectory="PreserveNewest"
          Link="libEGL.dylib" />
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.$(_RnwMacRid)\146.0.8\runtimes\$(_RnwMacRid)\native\libGLESv2.dylib"
          CopyToOutputDirectory="PreserveNewest"
          Link="libGLESv2.dylib" />
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.$(_RnwMacRid)\146.0.8\runtimes\$(_RnwMacRid)\native\libvk_swiftshader.dylib"
          CopyToOutputDirectory="PreserveNewest"
          Link="libvk_swiftshader.dylib" />
    <None Include="$(NuGetPackageRoot)harry.robust.natives.cef.$(_RnwMacRid)\146.0.8\runtimes\$(_RnwMacRid)\native\vk_swiftshader_icd.json"
          CopyToOutputDirectory="PreserveNewest"
          Link="vk_swiftshader_icd.json" />
  </ItemGroup>
</Project>
