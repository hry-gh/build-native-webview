    <PackageId>Harry.Robust.Natives.Cef.win-x64</PackageId>
    <PackageVersion>146.0.9</PackageVersion>
    <Authors>Space Wizards</Authors>
    <Description>Native CEF binaries for Windows x64 — part of Harry.Robust.Natives.Cef</Description>
